# Copy to omoda_sandbox.env and fill in. Region defaults = EU.
# account email (for OTP login)
OMODA_EMAIL=
# vehicle VIN
VIN=
# 6-digit car PIN (needed only for commands / taskId minting)
OMODA_PIN=
# BFF REST base (region)
OMODA_BFF=https://legend-oj.omodaauto.nl/api
# TSP telematics host (region)
TSP_HOST=https://tspconsole-eu.cheryinternational.com
# tenant code (region)
OMODA_TENANT_CODE=300006
# country id (1 = EU)
OMODA_COUNTRY_ID=1
# dept / phone prefix (39 = IT, 33 = FR, 49 = DE)
OMODA_DEPT_ID=39
# TSP SDK app id (region)
TSP_APP_ID=eu-1
# Accept-Language header
OMODA_LANGUAGE=en-GB
