{
  "config": {
    "step": {
      "user": {
        "title": "Omoda / Jaecoo",
        "description": "Enter your Omoda/Jaecoo account email and vehicle PIN. An OTP code will be sent to your email; VIN and account ID are detected automatically.",
        "data": {
          "email": "Account email",
          "pin": "Vehicle control PIN",
          "bff": "BFF endpoint (region)",
          "tsp_host": "TSP console host (region)",
