          "certs_src": "Folder with mutual-TLS certs to import (optional)"
        }
      },
      "otp": {
        "title": "Email verification code",
        "description": "Enter the OTP code received by email.",
        "data": {
          "code": "OTP code"
        }
      },
      "select_vehicle": {
        "title": "Select vehicle",
        "description": "Your account has more than one vehicle. Choose the VIN to add.",
        "data": {
          "vin": "Vehicle (VIN)"
        }
      },
      "reauth_confirm": {
        "title": "Re-authenticate Omoda / Jaecoo",
        "description": "Your session for {email} has expired (this happens when the official app is opened). A new OTP code has been sent to your email — enter it to reconnect.",
        "data": {
          "code": "OTP code"
        }
      }
    },
    "error": {
      "otp_send_failed": "Could not send the OTP code. Check the email/PIN and try again.",
      "otp_invalid": "Invalid or expired OTP code.",
      "no_vehicle": "Login succeeded but no vehicle was found on this account."
    },
    "abort": {
      "already_configured": "This vehicle (VIN) is already configured.",
      "token_move_failed": "Could not store the authentication token. Check Home Assistant's config folder permissions and try again.",
      "reauth_successful": "Re-authentication successful — the vehicle is reconnected."
    }
  },
