{
  "config": {
    "step": {
      "user": {
        "title": "Omoda / Jaecoo",
        "description": "Enter your Omoda/Jaecoo account email and vehicle PIN. An OTP code will be sent to your email; VIN and account ID are detected automatically.",
        "data": {
          "email": "Account email",
          "pin": "Vehicle control PIN",
          "bff": "BFF endpoint (region)",
          "tsp_host": "TSP console host (region)",
          "car_mqtt_host": "Vehicle MQTT broker host (region)",
          "car_mqtt_port": "Vehicle MQTT broker port (region)",
          "channel_id": "Channel ID (region)",
          "certs_src": "Folder with mutual-TLS certs to import (optional)"
        }
      },
      "otp": {
        "title": "Email verification code",
        "description": "Enter the OTP code received by email.",
        "data": {
          "code": "OTP code"
        }
      },
      "select_vehicle": {
        "title": "Select vehicle",
        "description": "Your account has more than one vehicle. Choose the VIN to add.",
        "data": {
          "vin": "Vehicle (VIN)"
        }
      },
      "reauth_confirm": {
        "title": "Re-authenticate Omoda / Jaecoo",
        "description": "Your session for {email} has expired (this happens when the official app is opened). A new OTP code has been sent to your email — enter it to reconnect.",
        "data": {
          "code": "OTP code"
        }
      }
    },
    "error": {
      "otp_send_failed": "Could not send the OTP code. Check the email/PIN and try again.",
      "otp_invalid": "Invalid or expired OTP code.",
      "no_vehicle": "Login succeeded but no vehicle was found on this account."
    },
    "abort": {
      "already_configured": "This vehicle (VIN) is already configured.",
      "token_move_failed": "Could not store the authentication token. Check Home Assistant's config folder permissions and try again.",
      "reauth_successful": "Re-authentication successful — the vehicle is reconnected."
    }
  },
  "options": {
    "step": {
      "init": {
        "title": "Omoda / Jaecoo — automatic updates",
        "description": "How often to wake the car and refresh telemetry + GPS position. 0 = disabled. The charging interval is used while the car is plugged in (telemetry refreshes more often to follow the charge).",
        "data": {
          "poll_normal_min": "Update interval when parked (minutes, 0 = off)",
          "poll_charging_min": "Update interval while plugged in (minutes, 0 = off)",
          "vehicle_name": "Vehicle name (leave empty to use the name detected from the car)",
          "vehicle_image": "Vehicle image URL (optional, shown on the card)"
        }
      }
    }
